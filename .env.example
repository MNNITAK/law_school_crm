# ---------- AI (server only — never NEXT_PUBLIC) ----------
# Provider selection: if GROQ_API_KEY is set it is PRIMARY; if ANTHROPIC_API_KEY
# is ALSO set it becomes the automatic fallback when Groq errors (429/5xx/timeout).
# PRODUCTION: set BOTH. Groq free tier caps at ~100k tokens/day — upgrade to the
# paid Developer tier before launch or the AI goes silent mid-day.

# Groq (primary): console.groq.com — Developer tier for production
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
# per-attempt Groq timeout in ms (default 15000)
# AI_TIMEOUT_MS=15000

# Anthropic (fallback / production quality): console.anthropic.com — set a ~$25 monthly spend cap
# ANTHROPIC_API_KEY=sk-ant-...
# cost lever: claude-opus-4-8 (best) | claude-sonnet-5 | claude-haiku-4-5-20251001 (cheapest)
ARIA_MODEL=claude-opus-4-8
TASK_MODEL=claude-haiku-4-5-20251001

# ---------- rumik.ai Silk TTS (voice calls; server only) ----------
# NOTE: rotate the key in the rumik dashboard before the client trial.
RUMIK_API_KEY=rk_live_...
RUMIK_MODEL=muga

# ---------- Firebase Admin (server only) ----------
# base64 of the service-account JSON:  PowerShell:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccount.json"))
FIREBASE_SERVICE_ACCOUNT_B64=

# ---------- Firebase Web SDK (safe to expose) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- WhatsApp Cloud API (Meta test number; server only) ----------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# any random string; enter the same value in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=clc-webhook-verify-2026

# ---------- Cron ----------
# Vercel sends this automatically when set in project env; guards /api/cron/followups
CRON_SECRET=
# named Firestore database id — leave empty for "(default)"
NEXT_PUBLIC_FIREBASE_DB_ID=

# ---------- Outbound AI calling (Vapi — vapi.ai) ----------
# Master switch for AUTOMATIC calls when a lead turns HOT (manual CRM button
# works whenever the Vapi keys exist). Calls only 9am-8pm IST, max 1/lead/day.
OUTBOUND_CALLS_ENABLED=false
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# random string; used to authenticate Vapi's end-of-call webhook
OUTBOUND_WEBHOOK_SECRET=
APP_BASE_URL=https://law-school-crm.vercel.app
# Global guards for autonomous calling (counsellor "Call now" is exempt from the
# daily budget but still respects the concurrency cap — Vapi PAYG hard limit is 10).
MAX_AUTO_CALLS_PER_DAY=250
MAX_CONCURRENT_CALLS=8
# optional tuning (defaults shown; current live setup = Vapi native V2 voice "Naina")
# VAPI_MODEL=gpt-4o-mini
# VAPI_VOICE_PROVIDER=vapi
# VAPI_VOICE_ID=Naina
# VAPI_STT_MODEL=nova-3
# VAPI_STT_LANG=multi   # Hindi↔English code-switching (Hinglish)

# ---------- Embeddable chat widget ----------
# Comma-separated origins allowed to embed /widget in an iframe (CSP frame-ancestors).
# Unset = any site may embed (trial default). Set to the client's website once known,
# e.g. https://citylawcollege.in,https://www.citylawcollege.in — then REDEPLOY
# (headers are baked in at build time).
WIDGET_ALLOWED_ORIGINS=

# ---------- Demo mode ----------
# true = no business-hours gate on auto-calls + 10-min call cooldown (not 24h). Set false in production.
DEMO_MODE=false
# auto-call score trigger (production: 70; demo: 50)
CALL_SCORE_THRESHOLD=70
